# Ambiente locale (docker-compose). Copia in `.env` per personalizzare.
# NB: valori solo per sviluppo locale, mai per la produzione.

# Database containerizzato (MariaDB)
DB_NAME=mariani
DB_USER=mariani
DB_PASSWORD=mariani
DB_ROOT_PASSWORD=root
DB_PORT=3307

# Porte host
WP_PORT=8890
PMA_PORT=8891

# Credenziali admin WordPress (create dallo script di setup)
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin
WP_ADMIN_EMAIL=dev@mariani.local
WP_TITLE=Mariani Concessionaria (locale)

# --- Frontend (web/.env.local) ---
# WP_API_URL             = API usata a build time (fetch contenuti)
# NEXT_PUBLIC_WP_API_URL = stessa API esposta al browser (POST /lead del form contatti)
# NEXT_PUBLIC_SITE_URL   = URL pubblico del sito (canonical/sitemap/OG)
# WP_API_URL=http://localhost:8890/wp-json/mariani/v1
# NEXT_PUBLIC_WP_API_URL=http://localhost:8890/wp-json/mariani/v1
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
